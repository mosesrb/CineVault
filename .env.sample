# CineVault Environment Variables Sample
# Save this file as `.env` in the root folder, or export these before running.
# E.g.: Set-Item -Path Env:delatron_jwtPrivateKey -Value "your_super_secret" (Windows/PowerShell)
# E.g.: export delatron_jwtPrivateKey="your_super_secret" (Linux/Mac)

# Required: The secret key used to sign JSON Web Tokens
delatron_jwtPrivateKey=cinevault_secret_key_change_me

# Optional: The TMDB API key to resolve film metadata (images, cast, summary, etc.)
# If left blank, CineVault uses a skeleton fallback for filenames
delatron_TMDB_API_KEY=your_tmdb_api_key_v3_here

# Required: The MongoDB connection string
delatron_MONGODB_URI=mongodb://localhost:27017/cinevault_production
